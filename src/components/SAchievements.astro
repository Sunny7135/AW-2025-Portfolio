---
// Achievements section
const achievements = [
  {
    year: "2025",
    title: "Google Adversarial Nibbler Project",
    desc: "Earned ₹18,000 for successfully completing the Google's Adversarial Nibbler Project organized by the School of Computer Science and Engineering. The project involved solving complex adversarial challenges and demonstrating strong algorithmic and problem-solving abilities.",
    icon: "🏆",
    img: "/images/Sunny kardam - Certificate.png"
  },
  {
    year: "2024",
    title: "500+ DSA Problems Solved",
    desc: "Solved over 500 Data Structures and Algorithms problems on platforms like LeetCode and GeeksforGeeks, strengthening problem-solving skills and deep understanding of complexity.",
    icon: "💻"
  },
  {
    year: "2023",
    title: "Full Stack Projects Built",
    desc: "Developed and deployed multiple modern web applications using the MERN stack, focusing on scalability and user experience.",
    icon: "🚀"
  }
];
---

<section id="achievements" class="s-achievements" data-intersect>
  <div class="s__inner">
    <h2 class="s__title">Achievements</h2>
    <p class="s__subtitle">Milestones and accomplishments that reflect my technical growth and real-world impact.</p>

    <div class="s-achieve__timeline">
      {achievements.map((item, index) => (
        <div class="s-achieve__item js-item">
          <div class="s-achieve__marker">
            <div class="marker-dot"></div>
          </div>
          
          <div class="s-achieve__card">
             <div class="s-achieve__header">
                <span class="s-achieve__icon">{item.icon}</span>
                <h3>{item.title}</h3>
                <span class="s-achieve__year">{item.year}</span>
             </div>
             
             <div class="s-achieve__body">
               <p>{item.desc}</p>
               {item.img && (
                 <div class="s-achieve__media">
                    <img src={item.img} alt={item.title} />
                 </div>
               )}
             </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  .s-achievements {
    padding: 10rem 0;
    background: color(primary);

    @include mq(phone) {
      padding: 5rem 1rem;
    }

    .s__inner {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .s__title {
      font: 700 4rem / 1 font-family(bigger);
      text-transform: uppercase;
      color: color(secondary);
      margin-bottom: 1rem;
      text-align: center;
      
      @include mq(phone) {
        font-size: 2.5rem;
      }
    }

    .s__subtitle {
      font: 400 1.2rem / 1.4 font-family(fraktion);
      color: color(secondary);
      text-align: center;
      margin-bottom: 5rem;
      opacity: 0.8;
    }

    .s-achieve__timeline {
      position: relative;
      padding-left: 3rem;

      &:before {
        content: '';
        position: absolute;
        left: 4px;
        top: 0;
        width: 2px;
        height: 100%;
        background: rgba(color(secondary), 0.2);
      }
      
      @include mq(phone) {
        padding-left: 1.5rem;
        &:before { left: 0; }
      }
    }

    .s-achieve__item {
      position: relative;
      margin-bottom: 4rem;

      &:last-child { margin-bottom: 0; }
    }

    .s-achieve__marker {
      position: absolute;
      left: -3rem;
      top: 10px;
      
      .marker-dot {
        width: 10px;
        height: 10px;
        background: color(secondary);
        border-radius: 50%;
        box-shadow: 0 0 15px color(secondary);
      }
      
      @include mq(phone) {
        left: -1.5rem;
      }
    }

    .s-achieve__card {
      background: rgba(color(secondary), 0.03);
      border: 1px solid rgba(color(secondary), 0.1);
      border-radius: 16px;
      padding: 2rem;
      
      @include mq(phone) {
        padding: 1.5rem;
      }
    }

    .s-achieve__header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.5rem;

      h3 {
        font: 700 1.5rem / 1.2 font-family(fraktion);
        color: color(secondary);
        margin: 0;
        flex: 1;
        
        @include mq(phone) { font-size: 1.2rem; }
      }

      .s-achieve__year {
        background: color(secondary);
        color: color(primary);
        padding: 2px 8px;
        font-family: font-family(fraktion);
        font-size: 0.8rem;
        border-radius: 4px;
      }

      .s-achieve__icon {
        font-size: 1.5rem;
      }
    }

    .s-achieve__body {
      color: color(secondary);
      font-size: 1.05rem;
      line-height: 1.6;
      opacity: 0.9;

      .s-achieve__media {
        margin-top: 2rem;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid rgba(color(secondary), 0.2);
        
        img {
          width: 100%;
          display: block;
        }
      }
    }
  }
</style>

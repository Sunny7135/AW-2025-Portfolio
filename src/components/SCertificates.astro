---
// Certificates section
const certificates = [
  {
    title: "Competitive Programming Batch",
    org: "AlgoTutor",
    date: "July 2025",
    img: "/images/Sunny kardam - Certificate.png",
    link: "/images/Sunny kardam - Certificate.png",
    highlights: ["Mastered Advanced Data Structures", "Optimized Algorithmic Performance", "Codeforces Contest Ready"]
  },
  {
    title: "Automation Anywhere (Robotics)",
    org: "Automation Anywhere",
    date: "Oct 2025",
    img: "/images/Screenshot 2025-12-19 at 15.39.19.pdf",
    link: "/images/Screenshot 2025-12-19 at 15.39.19.pdf",
    highlights: ["Robotic Process Automation Lifecycle", "Complex Workflow Automation", "AI-driven Bot Development"]
  },
  {
    title: "Network Fundamentals",
    org: "Coursera",
    date: "April 2025",
    img: "/images/coursera.pdf",
    link: "/images/coursera.pdf",
    highlights: ["TCP/IP Protocol Stack", "Network Security Fundamentals", "Routing & Switching Basics"]
  }
];
---

<section id="certificates" class="s-certificates" data-intersect>
  <div class="s-certificates__stars">
    {Array.from({ length: 12 }).map((_, i) => (
      <div class={`s-certificates__star s-certificates__star--${i + 1}`}></div>
    ))}
  </div>

  <div class="s__inner">
    <div class="s__header">
      <h2 class="s__title">
        <span class="s__title__main">Certificates & Achievements</span>
      </h2>
    </div>

    <div class="s-cert__grid">
      {certificates.map((cert, index) => (
        <div class={`s-cert__card js-card s-cert__card--${index + 1}`}>
          <div class="s-cert__visual">
            <div class="s-cert__visual__inner">
              {cert.img.endsWith('.pdf') ? (
                <iframe src={cert.img} title={cert.title} class="s-cert__iframe" />
              ) : (
                <img src={cert.img} alt={cert.title} loading="lazy" />
              )}
            </div>
            <div class="s-cert__overlay">
              <a href={cert.link} target="_blank" class="s-cert__view-btn">
                <span>View Full Certificate</span>
                <span class="icon">↗</span>
              </a>
            </div>
          </div>
          
          <div class="s-cert__content">
            <div class="s-cert__number">{String(index + 1).padStart(2, '0')}</div>
            <h3 class="s-cert__name">{cert.title}</h3>
            <div class="s-cert__details">
              <p class="s-cert__org">{cert.org}</p>
              <p class="s-cert__date">{cert.date}</p>
              
              {cert.highlights && (
                <ul class="s-cert__highlights">
                  {cert.highlights.map(h => <li>{h}</li>)}
                </ul>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  .s-certificates {
    position: relative;
    padding: 10rem 0;
    background: color(primary);
    overflow: hidden;

    &__stars {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 0;
    }

    &__star {
      position: absolute;
      width: 1.5rem;
      height: 1.5rem;
      background: color(secondary);
      mask: url('/images/asset-star.svg') center / contain no-repeat;
      opacity: 0.1;
      
      @for $i from 1 through 12 {
        &--#{$i} {
          top: random(100) * 1%;
          left: random(100) * 1%;
          animation: s-cert-star-#{$i} (8s + random(8s)) infinite ease-in-out alternate;
          animation-delay: random(5s) * -1s;
        }

        @keyframes s-cert-star-#{$i} {
          0% { transform: translate(0, 0) scale(0.8) rotate(0deg); opacity: 0.05; }
          100% { transform: translate(random(40) * 1px - 20px, random(40) * 1px - 20px) scale(1.2) rotate(45deg); opacity: 0.2; }
        }
      }
    }

    .s__inner {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 4rem;
      position: relative;
      z-index: 1;

      @include mq(phone) {
        padding: 0 1.5rem;
      }
    }

    .s__header {
      margin-bottom: 6rem;
      text-align: left;

      @include mq(phone) {
        margin-bottom: 3rem;
      }
    }

    .s__title {
      display: flex;
      flex-direction: column;
      
      &__main {
        font: 700 8rem / 0.8 font-family(bigger);
        text-transform: uppercase;
        color: color(secondary);
        
        @include mq(tablet) {
          font-size: 6rem;
        }
        @include mq(phone) {
          font-size: 3.5rem;
        }
      }
    }

    .s-cert__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
      
      @include mq(tablet) {
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
      }
      
      @include mq(phone) {
        grid-template-columns: 1fr;
      }
    }

    .s-cert__card {
      position: relative;
      display: flex;
      flex-direction: column;
      background: rgba(color(primary), 0.8);
      backdrop-filter: blur(10px);
      border: 1px solid color(secondary);
      padding: 1rem;
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);

      &:hover {
        transform: translateY(-10px);
        background: color(primary);
        
        .s-cert__overlay {
          opacity: 1;
        }
        
        .s-cert__visual img {
          transform: scale(1.05);
        }
      }
    }

    .s-cert__visual {
      position: relative;
      width: 100%;
      aspect-ratio: 4 / 3;
      background: rgba(color(secondary), 0.05);
      overflow: hidden;
      border-bottom: 1px solid color(secondary);
      margin-bottom: 1.5rem;

      &__inner {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s ease;
      }

      .s-cert__iframe {
        width: 100%;
        height: 100%;
        border: none;
        pointer-events: none;
      }
    }

    .s-cert__overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(color(primary), 0.9);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.3s ease;
      z-index: 2;
    }

    .s-cert__view-btn {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1rem 1.5rem;
      background: color(secondary);
      color: color(primary);
      text-decoration: none;
      font: 500 0.9rem font-family(fraktion);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      
      .icon {
        font-size: 1.1rem;
      }

      &:hover {
        background: color(primary);
        color: color(secondary);
        border: 1px solid color(secondary);
      }
    }

    .s-cert__content {
      position: relative;
      padding-top: 1rem;
    }

    .s-cert__number {
      font: 400 3rem / 1 font-family(editorial);
      color: color(secondary);
      opacity: 0.15;
      position: absolute;
      top: -0.5rem;
      right: 0;
    }

    .s-cert__name {
      font: 700 1.5rem / 1.2 font-family(fraktion);
      color: color(secondary);
      margin-bottom: 1.5rem;
      min-height: 3.6rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;

      @include mq(phone) {
        font-size: 1.25rem;
      }
    }

    .s-cert__details {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .s-cert__org {
      font: 500 0.9rem / 1.2 font-family(fraktion);
      color: color(secondary);
      text-transform: uppercase;
      letter-spacing: 0.02em;

      :global(.theme-contrasted) & {
        color: color(secondary); // Black is okay here
      }
    }

    .s-cert__date {
      font: 400 0.85rem / 1.2 font-family(fraktion);
      color: color(secondary);
      opacity: 0.6;

      :global(.theme-contrasted) & {
        color: color(white);
        opacity: 0.8;
      }
    }

    .s-cert__highlights {
      margin-top: 1rem;
      padding-left: 0.5rem;
      list-style: none;
      border-left: 1px solid rgba(color(secondary), 0.2);

      :global(.theme-contrasted) & {
        border-left-color: rgba(color(white), 0.3);
      }

      li {
        font: 400 0.8rem / 1.4 font-family(fraktion);
        color: color(secondary);
        opacity: 0.7;
        margin-bottom: 0.25rem;
        position: relative;
        padding-left: 0.75rem;

        :global(.theme-contrasted) & {
          color: color(white);
          opacity: 0.9;
        }

        &:before {
          content: '—';
          position: absolute;
          left: 0;
          opacity: 0.5;

          :global(.theme-contrasted) & {
            color: color(white);
          }
        }

        &:last-child { margin-bottom: 0; }
      }
    }
    
    // Fix decorative numbers for red theme
    .s-cert__card:after {
      :global(.theme-contrasted) & {
        color: color(white);
        opacity: 0.15;
      }
    }
  }
</style>

---
// Certificates section
const certificates = [
  {
    title: "Google's Adversarial Nibbler Project",
    org: "School of Computer Science & Engineering",
    date: "June 2025",
    img: "/images/Sunny kardam - Certificate.png",
    link: "#"
  },
  {
    title: "Data Structures and Algorithms",
    org: "Skillstone Institute",
    date: "June 2024",
    img: "/images/Screenshot 2025-12-19 at 15.39.19.pdf",
    link: "#"
  },
  {
    title: "Computer Communications Specialization",
    org: "University of Colorado System (Coursera)",
    date: "November 18, 2024",
    img: "/images/Screenshot 2025-12-19 at 15.39.19.pdf",
    link: "#"
  }
];
---

<section id="certificates" class="s-certificates" data-intersect>
  <div class="s__inner">
    <h2 class="s__title">Certifications</h2>
    <p class="s__subtitle">Professional validations of my technical expertise and continuous learning.</p>

    <div class="s-cert__grid">
      {certificates.map(cert => (
        <div class="s-cert__card js-card">
          <div class="s-cert__image">
            <img src={cert.img} alt={cert.title} />
          </div>
          <div class="s-cert__content">
            <h3>{cert.title}</h3>
            <div class="s-cert__meta">
              <span class="s-cert__org"><span class="icon">🏢</span> {cert.org}</span>
              <span class="s-cert__date"><span class="icon">📅</span> {cert.date}</span>
            </div>
            <a href={cert.link} class="s-cert__button" target="_blank">
              View Details <span class="arrow">↗</span>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  .s-certificates {
    padding: 10rem 0;
    background: color(primary);

    @include mq(phone) {
      padding: 5rem 1rem;
    }

    .s__inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .s__title {
      font: 700 4rem / 1 font-family(bigger);
      text-transform: uppercase;
      color: color(secondary);
      margin-bottom: 1rem;
      text-align: center;
      
      @include mq(phone) {
        font-size: 2.5rem;
      }
    }

    .s__subtitle {
      font: 400 1.2rem / 1.4 font-family(fraktion);
      color: color(secondary);
      text-align: center;
      margin-bottom: 5rem;
      opacity: 0.8;
    }

    .s-cert__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      
      @include mq(tablet) {
        grid-template-columns: repeat(2, 1fr);
      }
      
      @include mq(phone) {
        grid-template-columns: 1fr;
      }
    }

    .s-cert__card {
      background: rgba(color(secondary), 0.03);
      border: 1px solid rgba(color(secondary), 0.1);
      border-radius: 16px;
      overflow: hidden;
      transition: transform 0.3s ease, border-color 0.3s ease;
      display: flex;
      flex-direction: column;

      &:hover {
        transform: translateY(-5px);
        border-color: rgba(color(secondary), 0.3);
      }
    }

    .s-cert__image {
      width: 100%;
      height: 200px;
      background: rgba(color(secondary), 0.05);
      
      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
    }

    .s-cert__content {
      padding: 1.5rem;
      flex: 1;
      display: flex;
      flex-direction: column;

      h3 {
        font: 700 1.25rem / 1.3 font-family(fraktion);
        color: color(secondary);
        margin: 0 0 1rem 0;
        min-height: 3.25em;
      }
    }

    .s-cert__meta {
      font-size: 0.85rem;
      color: color(secondary);
      opacity: 0.7;
      margin-bottom: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      
      .icon { margin-right: 4px; }
    }

    .s-cert__button {
      margin-top: auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.75rem 1rem;
      background: rgba(color(secondary), 0.1);
      color: color(secondary);
      text-decoration: none;
      font-family: font-family(fraktion);
      font-size: 0.9rem;
      border-radius: 8px;
      transition: background 0.3s ease;

      &:hover {
        background: color(secondary);
        color: color(primary);
      }

      .arrow { margin-left: 6px; }
    }
  }
</style>
